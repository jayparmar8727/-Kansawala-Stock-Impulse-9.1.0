{%- comment -%}
  KANSAWALA fonts (9.1.0 migration · Phase 1)
  ----------------------------------------------------------------------
  Loads the two brand typefaces the KW custom sections use:
    --d  Jost                (display sans: headings, eyebrows, labels, buttons)
    --s  Cormorant Garamond  (serif italic accent lines, stat numerals)

  These are NOT part of Impulse's font_picker (which stays on Fahkwang for
  the stock site), so they're loaded directly from Google Fonts here,
  scoped to the KW design system via assets/kw-tokens.css. Rendered from
  layout/theme.liquid <head> alongside the other head partials.

  Async pattern: preconnect → preload → print/onload stylesheet swap, with
  a <noscript> fallback. See BRAND.md.
{%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Jost:wght@200;300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,700;1,300;1,400&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@200;300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,700;1,300;1,400&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@200;300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,700;1,300;1,400&display=swap"></noscript>
